---
import '../../styles/components/header/header-branding.css';
import { Image } from 'astro:assets';
import Logo from '../../resources/IronLogo.png';
---
<a
    href="/"
    id="header-branding-link"
>
    <Image
        src="data:image/webp;base64,"
        alt="Iron Riders Logo"
        id="header-logo"
        loading="lazy"
        decoding="async"
        fetchpriority="auto"
        width="100"
        height="100"
    />
    <span>Iron Riders</span>
</a>