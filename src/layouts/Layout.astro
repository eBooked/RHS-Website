---
/* Imports Tailwind */
import "../styles/global.css";

import Header from "../components/Nav/Header.astro";
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta charset="UTF-8" />
    <title>Iron Riders</title>
    <script src="../scripts/init.js"></script> <!-- Handles darkmode & space-to-click for accessibility -->

    <!-- This inline is for the to-top button, which is made an inline so prevent an abundance of scripts, as it's very simple -->
    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
      const btn = document.getElementById("back-to-top");
        // Scroll to top when clicked
        btn.addEventListener("click", () => {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      });
    </script>
  </head>

  <body class="bg-light-0 dark:bg-dark-600 text-light-1000 dark:text-dark-0 transition-colors duration-200 p-0 leading-normal">
    <!-- Back to top button, always on screen -->
    <button
    id="back-to-top"
    class="fixed bottom-5 right-5 bg-yellow-400 text-black px-4 py-2 rounded-full shadow-lg hover:bg-yellow-300 transition-colors"
    >
      ↑
    </button>

    <Header />

    <!-- Main Page Content -->
    <main>
      <slot />
    </main>

    <!-- Footer of each page; no components required. No 'secondary footer'. Simply stylized links and images :) 
         Sorry for the wall of hrefs... -->
    <footer class="border-t border-light-400 dark:border-dark-400 bg-light-300 dark:bg-dark-1000">
      <div class="max-w-6xl mx-auto px-6 py-10">
    
        <!-- Top section -->
        <div class="flex flex-col md:flex-row justify-between gap-8">
    
          <!-- Brand -->
          <div>
            <h2 class="text-lg font-semibold font-mono bg-golden-yellow dark:bg-golden-yellow dark:text-black p-2">The Iron Riders, FRC 4180</h2>
            <p class="text-sm font-mono text-light-600 dark:text-dark-100 mt-2 p-2">
            Roosevelt High School<br> 1410 NE 66th St <br> Seattle, WA 98115 
            </p>
          </div>
    
          <!-- Links (many!!!) -->
          <div class="grid grid-cols-3 gap-8 text-sm">
            <div class="flex flex-col space-y-2">
              <span class="font-medium font-mono">About Us</span>
              <a href="/team" class="hover:text-light-1000 dark:hover:text-dark-0 text-light-600 dark:text-dark-100 font-mono">Our Team</a>
              <a href="#" class="hover:text-light-1000 dark:hover:text-dark-0 text-light-600 dark:text-dark-100 font-mono">Gallery</a>
              <a href="#" class="hover:text-light-1000 dark:hover:text-dark-0 text-light-600 dark:text-dark-100 font-mono">Join</a>
            </div>
    
            <div class="flex flex-col space-y-2 font-mono">
              <span class="font-medium">Resources</span>
              <a href="/digital-resources" class="hover:text-light-1000 dark:hover:text-dark-0 text-light-600 dark:text-dark-100 font-mono">Digital</a>
              <a href="/calendar" class="hover:text-light-1000 dark:hover:text-dark-0 text-light-600 dark:text-dark-100 font-mono">Calendar</a>
              <a href="/sponsors" class="hover:text-light-1000 dark:hover:text-dark-0 text-light-600 dark:text-dark-100 font-mono">Sponsors</a>
            </div>

            <div class="flex flex-col space-y-2 font-mono">
              <span class="font-medium">Community</span>
              <a href="/outreach" class="hover:text-light-1000 dark:hover:text-dark-0 text-light-600 dark:text-dark-100">Outreach</a>
              <a href="/discord" class="hover:text-light-1000 dark:hover:text-dark-0 text-light-600 dark:text-dark-100">Discord</a>
              <a href="/donate" class="hover:text-light-1000 dark:hover:text-dark-0 text-light-600 dark:text-dark-100">Donate</a>
            </div>
          </div>
    
        </div>
    
        <!-- Bottom bar for footer -->
        <div class="mt-10 pt-6 border-t border-light-400 dark:border-dark-400 text-xs text-light-1000 dark:text-dark-100 text-center">
          <!-- If text wanted, put it here -->
        </div>
    
      </div>
    </footer>

  </body>
</html>