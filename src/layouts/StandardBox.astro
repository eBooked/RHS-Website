---
//Since we use a standard box to contain many objects, it's more practical to create a custom layout and input whatever in between.
---
<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div 
        class="py-5 rounded-xl border-2 bg-light-0 dark:bg-dark-500 border-light-300 dark:border-dark-400 shadow-md dark:shadow-none 
        text-light-1000 dark:text-dark-0 transition-colors duration-200"
    >
        <!-- Content goes here when used -->
        <slot />
    </div>
</div>