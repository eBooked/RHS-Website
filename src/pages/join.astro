---
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <!-- Wrapper for department section -->
	<div class="py-5 bg-light-200 dark:bg-dark-400">

		<!-- Title -->
		<div class="py-4 max-w-6xl mx-auto px-5 lg:px-8 bg-golden-yellow">
			<h1 class="text-3xl md:text-4xl font-semibold text-black font-mono">Join RHS Robotics!</h1>
		</div>
	
		<!-- Engineering Section -->
		<section class="py-6 md:py-8">
	
			<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
	
				<!-- Why Join Section -->
				<div class="flex flex-col items-center py-12 px-8">
					<h2 class="text-2xl font-bold font-mono mb-8">Why Join?</h2>
					<div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl w-full">
			
						<!-- Card 1 -->
						<div class="flex flex-col gap-2 p-6 bg-dark-200">
							<h3 class="text-dark-800 font-bold font-mono text-lg">Real-World Experience</h3>
							<p class="font-mono text-sm text-gray-700">
								Short description about this benefit or reason to join.
							</p>
						</div>
			
						<!-- Card 2 -->
						<div class="flex flex-col gap-2 p-6 bg-dark-200">
							<h3 class="text-dark-800 font-bold font-mono text-lg"></h3>
							<p class="font-mono text-sm text-gray-700">
								Short description about this benefit or reason to join.
							</p>
						</div>
			
						<!-- Card 3 -->
						<div class="flex flex-col gap-2 p-6 bg-dark-200">
							<h3 class="text-dark-800 font-bold font-mono text-lg">Amazing Community</h3>
							<p class="font-mono text-sm text-gray-700">
								Short description about this benefit or reason to join.
							</p>
						</div>
			
					</div>
				</div>
			</div>
		</section>
	</div>
</Layout>