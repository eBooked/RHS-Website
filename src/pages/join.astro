---
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <!-- Wrapper for formatting-->
	<div class="py-5 bg-light-200 dark:bg-dark-400">

		<!-- Title -->
		<div class="py-4 max-w-6xl mx-auto px-5 lg:px-8 bg-golden-yellow">
			<h1 class="text-3xl md:text-4xl font-semibold text-black font-mono">Join RHS Robotics!</h1>
		</div>
	
		<!-- Wrapper  -->
		<section class="py-6 md:py-8">
	
			<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
	
				<!-- Why Join Section -->
				<div class="flex flex-col items-center py-12 px-8">
					<h2 class="text-2xl font-bold font-mono mb-8">Why Join?</h2>
					<div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl w-full">
			
						<!-- Card 1 -->
						<div class="flex flex-col gap-2 p-6 bg-white dark:bg-gray-700">
							<h3 class="text-dark-800 font-bold font-mono text-lg dark:text-gray-200">Real-World Experience</h3>
							<p class="font-mono text-sm text-gray-700 dark:text-gray-400">
								In Robotics, you use real-world skills and learn how designing, managing, and creating projects happens everywhere.
							</p>
						</div>
			
						<!-- Card 2 -->
						<div class="flex flex-col gap-2 p-6 bg-white dark:bg-gray-700">
							<h3 class="text-dark-800 font-bold font-mono text-lg dark:text-gray-200">Learn New Skills</h3>
							<p class="font-mono text-sm text-gray-700 dark:text-gray-400">
								Robotics provides the oppertunity to try new things and learn new skills, such as CAD, programming, 3D-Printing, and more!
							</p>
						</div>
			
						<!-- Card 3 -->
						<div class="flex flex-col gap-2 p-6 bg-white dark:bg-gray-700">
							<h3 class="text-dark-800 font-bold font-mono text-lg dark:text-gray-200">Amazing Community</h3>
							<p class="font-mono text-sm text-gray-700 dark:text-gray-400">
								We have an incredible community of members, all of whom will support you through whatever!
							</p>
						</div>
					</div>
				</div>

			</div>

			<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col items-center py-12 px-8">
				<h1 class="text-3xl md:text-4xl font-semibold text-white font-mono">What to do to Join?</h1>

				<p class="py-6 font-mono text-lg text-gray-700 dark:text-gray-400">
					If you are interested in joining, there's mutliple ways to join--and don't worry, there's no forms or anything--just join the discord
					or get in contact with one of our leaders! They will help you in the easy process, and then you can attend meetings and join a specific group
					that works on the robot or helps the program.
				</p>
			</div>
		</section>
	</div>
</Layout>