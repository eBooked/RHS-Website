---
const discordInviteUrl = 'https://discord.com/invite/EzR3VyUQvF';
const homeUrl = '/';
---
<!-- Opens Discord in a new tab on click, then redirects this page to home -->
<!DOCTYPE html>
<html lang="en">
  <head>
  <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Join our Discord – Iron Riders</title>
    <link rel="canonical" href={discordInviteUrl} />
  </head>
  <body>
    <p>You are about to be redirected to Discord. Click here to continue.</p>
    <a href={discordInviteUrl} target="_blank" rel="noopener noreferrer" id="discord-link" style="display:inline-block;margin:1rem 0;padding:0.75rem 1.5rem;background:#5865F2;color:white;text-decoration:none;border-radius:8px;font-weight:600;">Open Discord</a>
    
    <!-- Inline-script for openning new tab, just for simplicity. Uses links established up top. -->
    <script is:inline define:vars={{ discordInviteUrl, homeUrl }}>

      //Simply gets the button using its ID and when a click event occurs, opens the new window discord, and links it to the join code.
      document.getElementById('discord-link').addEventListener('click', function(e) {
        window.open(discordInviteUrl, '_blank');
        e.preventDefault();
        setTimeout(function() { window.location.href = homeUrl; }, 300);
        return false;
      });
    </script>
  </body>
</html>
